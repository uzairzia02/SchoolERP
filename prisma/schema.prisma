// ============================================================
// School ERP — Prisma Schema
// Multi-Tenant SaaS | Production-Ready
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  PRINCIPAL
  HR
  ACCOUNTANT
  TEACHER
  FACULTY
  STUDENT
  PARENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  CASUAL
  SICK
  ANNUAL
  MATERNITY
  PATERNITY
  UNPAID
}

enum FeeStatus {
  PAID
  UNPAID
  PARTIAL
  WAIVED
  OVERDUE
}

enum AdmissionStatus {
  APPLIED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  ENROLLED
  WITHDRAWN
}

enum ExamType {
  MID_TERM
  FINAL
  QUIZ
  ASSIGNMENT
  PRACTICAL
}

enum TransportRoute {
  MORNING
  EVENING
  BOTH
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  URGENT
}

enum DocumentType {
  BIRTH_CERTIFICATE
  NATIONAL_ID
  PASSPORT
  TRANSCRIPT
  MEDICAL
  OTHER
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ─────────────────────────────────────────────────────────────
// SCHOOL (Root Tenant Entity)
// ─────────────────────────────────────────────────────────────

model School {
  id               String   @id @default(cuid())
  name             String
  code             String   @unique
  email            String   @unique
  phone            String
  address          String
  city             String
  state            String
  country          String
  zipCode          String
  website          String?
  logo             String?
  studentSequence  Int      @default(0)
  teacherSequence  Int      @default(0)
  employeeSequence Int      @default(0)
  isActive         Boolean  @default(true)
  timezone         String   @default("UTC")
  currency         String   @default("PKR")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  users              User[]
  students           Student[]
  parents            Parent[]
  teachers           Teacher[]
  employees          Employee[]
  departments        Department[]
  designations       Designation[]
  classes            Class[]
  sections           Section[]
  subjects           Subject[]
  timetables         Timetable[]
  exams              Exam[]
  assignments        Assignment[]
  fees               Fee[]
  payroll            Payroll[]
  transport          Transport[]
  events             Event[]
  news               News[]
  gallery            GalleryItem[]
  notifications      Notification[]
  documents          Document[]
  auditLogs          AuditLog[]
  admissions         Admission[]
  announcements      Announcement[]
  leaves             Leave[]
  holidays           Holiday[]
  settings           SchoolSettings?
  terms              Term[]
  gradeScales        GradeScale[]
  houses             House[]
  paymentSubmissions PaymentSubmission[]
  workingDays        WorkingDay[]
  schoolTimings      SchoolTiming[]
  Period             Period[]

  @@map("schools")
}

// ─────────────────────────────────────────────────────────────
// USER (Auth Entity)
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  schoolId      String
  email         String    @unique
  password      String
  role          UserRole
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  image         String?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  createdBy     String?
  updatedBy     String?

  // Relations
  school    School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student?
  parent    Parent?
  teacher   Teacher?
  employee  Employee?
  sessions  Session[]
  auditLogs AuditLog[]

  @@index([schoolId])
  @@index([email])
  @@index([role])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────
// STUDENT
// ─────────────────────────────────────────────────────────────

model Student {
  id              String      @id @default(cuid())
  schoolId        String
  userId          String      @unique
  admissionNumber String
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  gender          Gender
  bloodGroup      BloodGroup?
  religion        String?
  nationality     String?
  photo           String?
  phone           String?
  address         String?
  city            String?
  state           String?
  country         String?
  zipCode         String?
  classId         String?
  sectionId       String?
  rollNumber      String?
  admissionDate   DateTime    @default(now())
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  // Relations
  school             School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  class              Class?                 @relation(fields: [classId], references: [id])
  section            Section?               @relation(fields: [sectionId], references: [id])
  parents            StudentParent[]
  attendance         StudentAttendance[]
  grades             Grade[]
  fees               Fee[]
  assignments        AssignmentSubmission[]
  documents          Document[]
  transport          StudentTransport?
  notifications      Notification[]
  paymentSubmissions PaymentSubmission[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId])
  @@index([classId])
  @@index([sectionId])
  @@map("students")
}

// ─────────────────────────────────────────────────────────────
// PARENT
// ─────────────────────────────────────────────────────────────

model Parent {
  id         String    @id @default(cuid())
  schoolId   String
  userId     String    @unique
  firstName  String
  lastName   String
  email      String
  phone      String
  occupation String?
  photo      String?
  address    String?
  city       String?
  country    String?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  school   School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  students StudentParent[]

  @@index([schoolId])
  @@map("parents")
}

model StudentParent {
  id        String @id @default(cuid())
  studentId String
  parentId  String
  relation  String // Father, Mother, Guardian

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
  @@map("student_parents")
}

// ─────────────────────────────────────────────────────────────
// TEACHER
// ─────────────────────────────────────────────────────────────

model Teacher {
  id              String    @id @default(cuid())
  schoolId        String
  userId          String    @unique
  employeeId      String
  firstName       String
  lastName        String
  email           String
  phone           String
  dateOfBirth     DateTime?
  gender          Gender
  photo           String?
  address         String?
  departmentId    String?
  designationId   String?
  qualification   String?
  experience      Int?
  joiningDate     DateTime  @default(now())
  isActive        Boolean   @default(true)
  lastWorkingDate DateTime?
  leavingReason   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  school      School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  department  Department?       @relation(fields: [departmentId], references: [id])
  designation Designation?      @relation(fields: [designationId], references: [id])
  subjects    TeacherSubject[]
  timetables  Timetable[]
  attendance  StaffAttendance[]
  assignments Assignment[]
  leaves      Leave[]

  @@unique([schoolId, employeeId])
  @@index([schoolId])
  @@map("teachers")
}

// ─────────────────────────────────────────────────────────────
// EMPLOYEE (non-teaching staff)
// ─────────────────────────────────────────────────────────────

model Employee {
  id              String    @id @default(cuid())
  schoolId        String
  userId          String    @unique
  employeeId      String
  firstName       String
  lastName        String
  email           String
  phone           String
  dateOfBirth     DateTime?
  gender          Gender
  photo           String?
  address         String?
  departmentId    String?
  designationId   String?
  lastWorkingDate DateTime?
  leavingReason   String?
  salary          Decimal?  @db.Decimal(10, 2)
  joiningDate     DateTime  @default(now())
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  createdBy       String?
  updatedBy       String?

  school      School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  department  Department?       @relation(fields: [departmentId], references: [id])
  designation Designation?      @relation(fields: [designationId], references: [id])
  payroll     Payroll[]
  attendance  StaffAttendance[]
  leaves      Leave[]
  documents   Document[]

  @@unique([schoolId, employeeId])
  @@index([schoolId])
  @@map("employees")
}

// ─────────────────────────────────────────────────────────────
// DEPARTMENT & DESIGNATION
// ─────────────────────────────────────────────────────────────

model Department {
  id          String    @id @default(cuid())
  schoolId    String
  name        String
  code        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teachers     Teacher[]
  employees    Employee[]
  designations Designation[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("departments")
}

model Designation {
  id           String    @id @default(cuid())
  schoolId     String
  departmentId String?
  name         String
  description  String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  school     School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])
  teachers   Teacher[]
  employees  Employee[]

  @@index([schoolId])
  @@map("designations")
}

// ─────────────────────────────────────────────────────────────
// ACADEMIC STRUCTURE
// ─────────────────────────────────────────────────────────────

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classes Class[]
  exams   Exam[]

  @@index([schoolId])
  @@map("academic_years")
}

model Class {
  id             String    @id @default(cuid())
  schoolId       String
  academicYearId String?
  name           String
  displayName    String
  order          Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  school       School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear?  @relation(fields: [academicYearId], references: [id])
  sections     Section[]
  students     Student[]
  subjects     ClassSubject[]
  timetables   Timetable[]
  exams        Exam[]
  assignments  Assignment[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("classes")
}

model Section {
  id        String    @id @default(cuid())
  schoolId  String
  classId   String
  name      String
  capacity  Int       @default(40)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  school     School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class      Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  students   Student[]
  timetables Timetable[]
  attendance StudentAttendance[]

  @@unique([classId, name])
  @@index([schoolId])
  @@index([classId])
  @@map("sections")
}

model Subject {
  id          String    @id @default(cuid())
  schoolId    String
  name        String
  code        String
  description String?
  creditHours Int       @default(1)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  school      School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes     ClassSubject[]
  teachers    TeacherSubject[]
  timetables  Timetable[]
  grades      Grade[]
  exams       ExamSubject[]
  assignments Assignment[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("subjects")
}

// ─────────────────────────────────────────────
// CLASS SUBJECT MAPPING
// ─────────────────────────────────────────────

model ClassSubject {
  id String @id @default(cuid())

  classId   String
  subjectId String

  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([classId, subjectId])
  @@index([classId])
  @@index([subjectId])
  @@map("class_subjects")
}

model TeacherSubject {
  id        String @id @default(cuid())
  teacherId String
  subjectId String

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
  @@map("teacher_subjects")
}

// ─────────────────────────────────────────────────────────────
// TIMETABLE
// ─────────────────────────────────────────────────────────────

model Timetable {
  id String @id @default(cuid())

  schoolId  String
  classId   String
  sectionId String?

  subjectId String
  teacherId String
  periodId  String

  dayOfWeek DayOfWeek

  room String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  section Section? @relation(fields: [sectionId], references: [id])

  subject Subject @relation(fields: [subjectId], references: [id])

  teacher Teacher @relation(fields: [teacherId], references: [id])

  period Period @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([classId, sectionId, dayOfWeek, periodId])
  @@index([schoolId])
  @@index([classId])
  @@index([teacherId])
  @@map("timetables")
}

