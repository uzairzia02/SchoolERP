// ─────────────────────────────────────────────────────────────
// EXAMINATION & GRADES
// ─────────────────────────────────────────────────────────────

model Exam {
  id             String    @id @default(cuid())
  schoolId       String
  academicYearId String?
  classId        String
  name           String
  type           ExamType
  startDate      DateTime
  endDate        DateTime
  totalMarks     Int
  passingMarks   Int
  isPublished    Boolean   @default(false)
  attachments    String[]  @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  createdBy      String?

  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id])
  class        Class         @relation(fields: [classId], references: [id])
  subjects     ExamSubject[]
  grades       Grade[]

  @@index([schoolId])
  @@map("exams")
}

model ExamSubject {
  id           String    @id @default(cuid())
  examId       String
  subjectId    String
  totalMarks   Int
  passingMarks Int
  date         DateTime?
  duration     Int?

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([examId, subjectId])
  @@map("exam_subjects")
}

model Grade {
  id         String   @id @default(cuid())
  schoolId   String
  studentId  String
  examId     String
  subjectId  String
  marksObt   Decimal  @db.Decimal(6, 2)
  totalMarks Decimal  @db.Decimal(6, 2)
  percentage Decimal  @db.Decimal(5, 2)
  grade      String
  gpa        Decimal? @db.Decimal(3, 2)
  remarks    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?

  student Student @relation(fields: [studentId], references: [id])
  exam    Exam    @relation(fields: [examId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([studentId, examId, subjectId])
  @@index([schoolId])
  @@map("grades")
}

// ─────────────────────────────────────────────────────────────
// ASSIGNMENTS & HOMEWORK
// ─────────────────────────────────────────────────────────────

model Assignment {
  id          String    @id @default(cuid())
  schoolId    String
  teacherId   String
  subjectId   String
  classId     String?
  title       String
  description String?
  dueDate     DateTime
  totalMarks  Int?
  attachments String[]
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  school      School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher     Teacher                @relation(fields: [teacherId], references: [id])
  subject     Subject                @relation(fields: [subjectId], references: [id])
  class       Class?                 @relation(fields: [classId], references: [id])
  submissions AssignmentSubmission[]

  @@index([schoolId])
  @@map("assignments")
}

model AssignmentSubmission {
  id           String   @id @default(cuid())
  assignmentId String
  studentId    String
  content      String?
  attachments  String[]
  marksObt     Decimal? @db.Decimal(6, 2)
  feedback     String?
  submittedAt  DateTime @default(now())
  isLate       Boolean  @default(false)
  updatedAt    DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@map("assignment_submissions")
}

// ─────────────────────────────────────────────────────────────
// FEE MANAGEMENT
// ─────────────────────────────────────────────────────────────

model FeeType {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  description String?
  amount      Decimal  @db.Decimal(10, 2)
  isRecurring Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fees Fee[]

  @@index([schoolId])
  @@map("fee_types")
}

model Fee {
  id            String         @id @default(cuid())
  schoolId      String
  studentId     String
  feeTypeId     String
  amount        Decimal        @db.Decimal(10, 2)
  discount      Decimal        @default(0) @db.Decimal(10, 2)
  fine          Decimal        @default(0) @db.Decimal(10, 2)
  paidAmount    Decimal        @default(0) @db.Decimal(10, 2)
  dueDate       DateTime
  paidDate      DateTime?
  status        FeeStatus      @default(UNPAID)
  paymentMethod PaymentMethod?
  receiptNumber String?
  remarks       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdBy     String?

  school             School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student            Student             @relation(fields: [studentId], references: [id])
  feeType            FeeType             @relation(fields: [feeTypeId], references: [id])
  paymentSubmissions PaymentSubmission[]

  @@index([schoolId])
  @@index([studentId])
  @@map("fees")
}

// ─────────────────────────────────────────────────────────────
// PAYROLL
// ─────────────────────────────────────────────────────────────

model Payroll {
  id            String         @id @default(cuid())
  schoolId      String
  employeeId    String
  month         Int
  year          Int
  basicSalary   Decimal        @db.Decimal(10, 2)
  allowances    Decimal        @default(0) @db.Decimal(10, 2)
  deductions    Decimal        @default(0) @db.Decimal(10, 2)
  netSalary     Decimal        @db.Decimal(10, 2)
  paidDate      DateTime?
  paymentMethod PaymentMethod?
  remarks       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdBy     String?

  school   School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
  @@index([schoolId])
  @@map("payroll")
}

// ─────────────────────────────────────────────────────────────
// TRANSPORT
// ─────────────────────────────────────────────────────────────

model Transport {
  id          String   @id @default(cuid())
  schoolId    String
  routeName   String
  routeNumber String
  driverName  String
  driverPhone String
  vehicleNo   String
  capacity    Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school   School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students StudentTransport[]

  @@unique([schoolId, routeNumber])
  @@index([schoolId])
  @@map("transport")
}

model StudentTransport {
  id          String         @id @default(cuid())
  studentId   String         @unique
  transportId String
  route       TransportRoute
  pickupPoint String?
  fee         Decimal?       @db.Decimal(10, 2)
  createdAt   DateTime       @default(now())

  student   Student   @relation(fields: [studentId], references: [id])
  transport Transport @relation(fields: [transportId], references: [id])

  @@map("student_transport")
}

// ─────────────────────────────────────────────────────────────
// LEAVES
// ─────────────────────────────────────────────────────────────

model Leave {
  id         String      @id @default(cuid())
  schoolId   String
  teacherId  String?
  employeeId String?
  type       LeaveType
  startDate  DateTime
  endDate    DateTime
  totalDays  Int
  reason     String
  status     LeaveStatus @default(PENDING)
  approvedBy String?
  remarks    String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher  Teacher?  @relation(fields: [teacherId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@index([schoolId])
  @@map("leaves")
}

// ─────────────────────────────────────────────────────────────
// EVENTS, NEWS, ANNOUNCEMENTS
// ─────────────────────────────────────────────────────────────

model Event {
  id          String    @id @default(cuid())
  schoolId    String
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  location    String?
  image       String?
  isPublic    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("events")
}

model News {
  id          String    @id @default(cuid())
  schoolId    String
  title       String
  content     String
  image       String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("news")
}

model Announcement {
  id          String     @id @default(cuid())
  schoolId    String
  title       String
  content     String
  targetRoles UserRole[]
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdBy   String?

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("announcements")
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATIONS, GALLERY, DOCUMENTS
// ─────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  schoolId  String
  userId    String?
  studentId String?
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  school  School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id])

  @@index([schoolId])
  @@index([userId])
  @@map("notifications")
}

model GalleryItem {
  id        String   @id @default(cuid())
  schoolId  String
  title     String?
  imageUrl  String
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("gallery_items")
}

model Document {
  id         String       @id @default(cuid())
  schoolId   String
  name       String
  type       DocumentType
  url        String
  studentId  String?
  employeeId String?
  isVerified Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student  Student?  @relation(fields: [studentId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@index([schoolId])
  @@map("documents")
}

// ─────────────────────────────────────────────────────────────
// ADMISSIONS
// ─────────────────────────────────────────────────────────────

model Admission {
  id               String          @id @default(cuid())
  schoolId         String
  firstName        String
  lastName         String
  email            String?
  phone            String?
  dateOfBirth      DateTime
  gender           Gender
  religion         String?
  nationality      String?
  address          String?
  city             String?
  country          String?
  applyingForClass String
  status           AdmissionStatus @default(APPLIED)
  documents        String[]
  remarks          String?
  appliedAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  reviewedBy       String?

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("admissions")
}

// ─────────────────────────────────────────────────────────────
// HOLIDAYS
// ─────────────────────────────────────────────────────────────

model Holiday {
  id          String   @id @default(cuid())
  schoolId    String
  name        String
  date        DateTime @db.Date
  description String?
  createdAt   DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("holidays")
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([schoolId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// SETTINGS
// ─────────────────────────────────────────────────────────────

model SchoolSettings {
  id                String    @id @default(cuid())
  schoolId          String    @unique
  // Academic
  currentSession    String    @default("2025-2026")
  sessionStartDate  DateTime?
  sessionEndDate    DateTime?
  termsCount        Int       @default(3)
  // Grading
  gradingSystem     Json?
  passingMarks      Int       @default(33)
  // Finance
  bankName          String?
  bankAccountNumber String?
  bankBranch        String?
  // Notifications
  smsApiKey         String?
  smsApiUrl         String?
  smsMasking        String?
  smsAbsentTemplate String?
  smsFeeTemplate    String?
  smsResultTemplate String?
  // System
  timezone          String    @default("Asia/Karachi")
  currency          String    @default("PKR")
  dateFormat        String    @default("DD/MM/YYYY")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("school_settings")
}

// ─────────────────────────────────────────────
// WORKING DAYS
// ─────────────────────────────────────────────

model WorkingDay {
  id          String    @id @default(cuid())
  schoolId    String
  day         DayOfWeek
  isWorking   Boolean   @default(true)
  startTime   String?
  endTime     String?
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, day])
  @@index([schoolId])
  @@map("working_days")
}

// ─────────────────────────────────────────────
// SCHOOL TIMINGS
// ─────────────────────────────────────────────

model SchoolTiming {
  id       String @id @default(cuid())
  schoolId String

  name      String
  startTime String
  endTime   String

  breakStart String?
  breakEnd   String?

  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("school_timings")
}

model Term {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  startDate DateTime
  endDate   DateTime
  session   String
  weightage Int      @default(33)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("terms")
}

model GradeScale {
  id        String   @id @default(cuid())
  schoolId  String
  grade     String
  minMarks  Int
  maxMarks  Int
  gpa       Float
  remarks   String?
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("grade_scales")
}

model House {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  color     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("houses")
}

model StudentAttendance {
  id        String           @id @default(cuid())
  schoolId  String
  date      DateTime         @db.Date
  status    AttendanceStatus
  remarks   String?
  studentId String
  sectionId String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  createdBy String?

  student Student @relation(fields: [studentId], references: [id])

  section Section? @relation(fields: [sectionId], references: [id])

  @@unique([studentId, date])
  @@index([schoolId, date])
  @@map("student_attendance")
}

model StaffAttendance {
  id       String           @id @default(cuid())
  schoolId String
  date     DateTime         @db.Date
  status   AttendanceStatus
  checkIn  DateTime? // Staff ke liye check-in time tracking
  checkOut DateTime? // Staff ke liye check-out time tracking
  remarks  String?

  // Dono mein se ek user type hoga (Ya Teacher ya Non-Teaching Staff)
  teacherId  String?
  employeeId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  teacher  Teacher?  @relation(fields: [teacherId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@index([schoolId, date])
  @@map("staff_attendance")
}

enum PaymentSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model PaymentSubmission {
  id                String                  @id @default(cuid())
  schoolId          String
  feeId             String
  studentId         String
  submittedBy       String // Parent's User id
  paymentMethod     PaymentMethod
  referenceNumber   String
  amount            Decimal                 @db.Decimal(10, 2)
  status            PaymentSubmissionStatus @default(PENDING)
  transactionNumber String? // generated only upon approval
  reviewedBy        String?
  reviewedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fee     Fee     @relation(fields: [feeId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@index([schoolId])
  @@index([feeId])
  @@map("payment_submissions")
}

// ─────────────────────────────────────────────
// PERIOD MASTER
// ─────────────────────────────────────────────

model Period {
  id       String @id @default(cuid())
  schoolId String

  name     String
  periodNo Int

  startTime String
  endTime   String

  duration Int
  isBreak  Boolean @default(false)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  timetables Timetable[]

  @@unique([schoolId, periodNo])
  @@index([schoolId])
  @@map("periods")
}
